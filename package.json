{
  "name": "atlas-design-system",
  "version": "2.1.0",
  "description": "A react native design system for the Atlas workout app",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    }
  },
  "sideEffects": false,
  "repository": {
    "type": "git",
    "url": "git+https://github.com/juancstlm/AtlasDesignSystem.git"
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "lint": "eslint 'src/**/*.{ts,tsx}' && tsc --noEmit",
    "lint:fix": "eslint 'src/**/*.{ts,tsx}' --fix",
    "test": "echo \"No tests configured\" && exit 0",
    "example": "yarn --cwd example",
    "build": "tsc",
    "patch": "npm version patch",
    "minor": "npm version minor",
    "watch": "tsc --watch",
    "publish:dryrun": "npm publish --dry-run",
    "prepublishOnly": "yarn lint && yarn build"
  },
  "keywords": [
    "react-native",
    "ui",
    "components",
    "design-system",
    "theming",
    "typescript",
    "ios",
    "android"
  ],
  "homepage": "https://github.com/juancstlm/AtlasDesignSystem#readme",
  "bugs": {
    "url": "https://github.com/juancstlm/AtlasDesignSystem/issues"
  },
  "engines": {
    "node": ">=18"
  },
  "peerDependencies": {
    "@react-native-community/datetimepicker": ">=8.0.0",
    "informed": ">=4.61.0",
    "moment": ">=2.24.0",
    "react": ">=18.0.0",
    "react-native": ">=0.72.0",
    "react-native-reanimated": ">=3.17.4",
    "react-native-safe-area-context": ">=5.0.0",
    "react-native-vector-icons": ">=10.0.0"
  },
  "peerDependenciesMeta": {
    "@react-native-community/datetimepicker": {
      "optional": true
    },
    "informed": {
      "optional": true
    },
    "moment": {
      "optional": true
    },
    "react-native-vector-icons": {
      "optional": true
    }
  },
  "devDependencies": {
    "@react-native-community/datetimepicker": "~8.0.1",
    "@types/react": "^19.0.0",
    "@types/react-native-vector-icons": "^6.4.18",
    "@typescript-eslint/eslint-plugin": "^8.4.0",
    "@typescript-eslint/parser": "^8.4.0",
    "eslint": "^8.19.0",
    "eslint-plugin-import": "^2.31.0",
    "eslint-plugin-react": "^7.35.2",
    "eslint-plugin-react-native": "^4.1.0",
    "eslint-plugin-unused-imports": "^4.1.4",
    "informed": "^4.66.0",
    "moment": "^2.29.0",
    "react": "^19.0.0",
    "react-native": "0.79.5",
    "react-native-reanimated": "~3.17.4",
    "react-native-safe-area-context": "^5.4.0",
    "react-native-vector-icons": "^10.1.0",
    "typescript": "^5.5.4"
  },
  "author": "Juan Castillo",
  "license": "ISC"
}
